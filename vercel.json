{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "espacioauditorium.com.ar" }],
      "destination": "https://www.espacioauditorium.com.ar/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/reservations/:id", "destination": "/api/reservations/[id]" },
    { "source": "/salas", "destination": "/salas/index.html" },
    { "source": "/cotizar", "destination": "/cotizar/index.html" },
    { "source": "/conferencias", "destination": "/conferencias/index.html" },
    { "source": "/capacitaciones", "destination": "/capacitaciones/index.html" },
    { "source": "/podcast-y-streaming", "destination": "/podcast-y-streaming/index.html" },
    { "source": "/lanzamientos", "destination": "/lanzamientos/index.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/send-reminders",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/payment-reminder",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/auto-cancel",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/keep-alive",
      "schedule": "0 9 * * *"
    }
  ]
}
