{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/reservations/:id", "destination": "/api/reservations/[id]" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/send-reminders",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/payment-reminder",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/auto-cancel",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/keep-alive",
      "schedule": "0 9 */5 * *"
    }
  ]
}
