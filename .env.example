# ============================================================
# ESPACIO AUDITORIUM - Variables de entorno
# Copiá este archivo como .env.local para desarrollo
# En Vercel, cargá estas variables en Settings > Environment Variables
# ============================================================

# --- SUPABASE ---
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- MERCADO PAGO ---
VITE_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000

# --- GOOGLE CALENDAR ---
# ID del calendario (generalmente el email de la cuenta)
GOOGLE_CALENDAR_ID=espacioauditorium@gmail.com
# Service Account JSON completo (como string JSON, sin saltos de línea)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# --- EMAIL (NODEMAILER via Gmail SMTP) ---
# Usá una App Password de Google (no la contraseña de la cuenta)
# Configuración: Google Account > Security > 2-Step Verification > App passwords
EMAIL_USER=espacioauditorium@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- WHATSAPP NOTIFICACIONES (CallMeBot) ---
# Registrate en https://www.callmebot.com/blog/free-api-whatsapp-messages/
# El número del negocio que recibirá la notificación
CALLMEBOT_PHONE=5491138255877
CALLMEBOT_APIKEY=xxxxxxx

# --- WHATSAPP BOT (Meta Cloud API) ---
# Token de acceso permanente desde Meta Business Manager
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxx
# ID del número de teléfono registrado en Meta (no es el número, es el ID)
WHATSAPP_PHONE_ID=1234567890
# Token de verificación del webhook (inventalo vos, cualquier string)
WHATSAPP_VERIFY_TOKEN=mi-token-secreto-auditorium
# Número humano al que deriva el bot (formato internacional sin +)
HUMAN_WHATSAPP_NUMBER=5491138255877

# --- CLAUDE AI (para el bot de WhatsApp) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- APP ---
# URL pública del deploy (sin barra al final)
VITE_APP_URL=https://espacio-auditorium.vercel.app
# Contraseña para el panel de admin (server-side: NO usar prefijo VITE_)
ADMIN_PASSWORD=cambiar-esto-en-produccion
# Secreto para el endpoint de test post-pago (eliminar este endpoint en producción real)
TEST_NOTIFY_SECRET=cambiar-esto-en-produccion

# --- VERCEL (solo en local para simular webhooks) ---
# No es necesario en producción
VITE_VERCEL_ENV=development
